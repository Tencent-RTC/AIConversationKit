<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <com.trtc.uikit.aiconversationkit.view.AIConversationCoreView
        android:id="@+id/conversation_view_ai_conversation_core"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <com.trtc.uikit.aiconversationkit.view.AIConversationSubtitleView
        android:id="@+id/conversation_view_ai_subtitle"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="148dp"
        android:layout_marginBottom="148dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <com.trtc.uikit.aiconversationkit.view.AIConversationControlView
        android:id="@+id/conversation_view_control"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="30dp"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
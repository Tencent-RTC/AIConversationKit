<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <com.trtc.uikit.aiconversationkit.view.feature.MicView
        android:id="@+id/conversation_mic_view"
        android:layout_width="@dimen/feature_button_size"
        android:layout_height="@dimen/feature_button_size"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/conversation_ai_interaction_view"
        app:layout_constraintHorizontal_chainStyle="spread"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.trtc.uikit.aiconversationkit.view.feature.AIInteractionView
        android:id="@+id/conversation_ai_interaction_view"
        android:layout_width="@dimen/feature_button_size"
        android:layout_height="@dimen/feature_button_size"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/conversation_hang_up_view"
        app:layout_constraintStart_toEndOf="@+id/conversation_mic_view"
        app:layout_constraintTop_toTopOf="parent" />

    <com.trtc.uikit.aiconversationkit.view.feature.HangUpView
        android:id="@+id/conversation_hang_up_view"
        android:layout_width="@dimen/feature_button_size"
        android:layout_height="@dimen/feature_button_size"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/conversation_ai_interaction_view"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
